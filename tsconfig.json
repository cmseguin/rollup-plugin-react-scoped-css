{
  "compilerOptions": {
    "target": "ES2021",
    "module": "preserve",
    "rewriteRelativeImportExtensions": true,
    "moduleResolution": "bundler",
    "declaration": true,
    "rootDir": "./src",
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true
  },
  "exclude": [
    "node_modules",
    "dist",
    "**/*.spec.*",
    "examples/**?*"
  ]
}